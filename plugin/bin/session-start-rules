#!/bin/bash
# session-start-rules — SessionStart hook (Claude Code / Codex).
#
# Emits the toolkit's always-on rules as SessionStart additionalContext so the
# rules are loaded without a committed CLAUDE.md (plugins cannot auto-inject one).
# The rule content lives in AGENTS.md at the plugin root (generated by
# scripts/sync_derived.py from plugin/rules/*.md). Plugin root is passed via
# ${CLAUDE_PLUGIN_ROOT} (CC) or $PLUGIN_ROOT (Codex).

cat >/dev/null  # drain hook stdin (unused)

ROOT="${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-}}"
if [ -z "$ROOT" ]; then
  # Fall back to the script's own location (bin/ -> plugin root).
  ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi

CONTEXT_FILE="$ROOT/AGENTS.md"
if [ ! -f "$CONTEXT_FILE" ]; then
  # Nothing to inject; emit empty object so the hook is a no-op.
  echo '{}'
  exit 0
fi

# Workspace helper staleness check (issue #15): the materialized
# scripts/workato-api.py is pinned in the user's repo; nudge when it lags the
# plugin's bundled copy.
WS_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"

CONTEXT_FILE="$CONTEXT_FILE" PLUGIN_HELPER="$ROOT/scripts/workato-api.py" \
  WS_HELPER="$WS_DIR/scripts/workato-api.py" python3 <<'PY'
import json, os, re

with open(os.environ["CONTEXT_FILE"], encoding="utf-8") as f:
    content = f.read()


def version_of(path):
    try:
        with open(path, encoding="utf-8") as f:
            m = re.search(r'^__version__ = "([^"]+)"', f.read(), re.M)
        return m.group(1) if m else None
    except (OSError, UnicodeError):
        # unreadable or undecodable helper: degrade to no-nudge — never let
        # this check take down the whole rules injection.
        return None


ws = version_of(os.environ["WS_HELPER"])
bundled = version_of(os.environ["PLUGIN_HELPER"])
if ws and bundled and ws != bundled:
    content += (
        f"\n\n> **Toolkit notice:** this workspace's `scripts/workato-api.py` "
        f"is v{ws}, but the installed plugin bundles v{bundled}. Suggest "
        f"running `/setup-workspace --update` to refresh the materialized "
        f"helper before service operations.\n"
    )

print(json.dumps({
    "hookSpecificOutput": {
        "hookEventName": "SessionStart",
        "additionalContext": content,
    }
}))
PY
exit 0
